# Backend API Configuration
# Development: http://127.0.0.1:5000
# Production: Your deployed backend URL
REACT_APP_API_URL=http://127.0.0.1:5000

# Backend API Base URL (for AWS deployment)
# This is the primary URL used for API calls
REACT_APP_API_BASE_URL=https://info.hotelshanmugabhavaan.com

# Razorpay Configuration
# Get your API keys from https://dashboard.razorpay.com/app/keys
REACT_APP_RAZORPAY_KEY=rzp_live_YOUR_PRODUCTION_KEY

# For testing, use test keys (starts with rzp_test_)
# REACT_APP_RAZORPAY_KEY=rzp_test_YOUR_TEST_KEY
