# Frontend Environment Variables Template
# Copy this to frontend/.env and fill in your values

# Google OAuth Client ID (from Google Cloud Console)
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# API Base URL (Primary - used for AWS deployment)
REACT_APP_API_BASE_URL=https://info.hotelshanmugabhavaan.com

# API URL (Fallback)
# Development:
REACT_APP_API_URL=http://127.0.0.1:5000

# Production (update with your domain):
# REACT_APP_API_URL=https://api.yourdomain.com

# Razorpay Key (if using payment gateway)
# Get from https://dashboard.razorpay.com/app/keys
REACT_APP_RAZORPAY_KEY=rzp_test_YOUR_KEY_HERE
